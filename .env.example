APP_NAME=LaravelAdmin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=3000

APP_MODE=full

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
DEFAULT_PAGE_SIZE=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laraveladmin
# DB_USERNAME=root
# DB_PASSWORD=

# Session storage driver: database | redis | file
# - database : simpan sesi di tabel `sessions` DB utama (default, persist lintas restart)
# - redis    : simpan sesi di Redis (cepat, hilang saat Redis restart)
# - file     : simpan sesi di filesystem (tidak cocok untuk multi-instance)
SESSION_DRIVER=database
SESSION_TTL_HOURS=6
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis

REDIS_URL=redis://127.0.0.1:6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_SECURE=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@laraveladmin.test"
MAIL_FROM_NAME="${APP_NAME}"

STORAGE_DRIVER=local
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_SSL=true

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=changeme_min32chars_jwt_secret_key
JWT_EXPIRES_IN=1h

SESSION_SECRET=changeme_session_secret_key
